data = pd.read_csv("hotel_bookings.csv")

data.drop(["company", "agent"], axis=1, inplace=True)

data.dropna(inplace=True)

data.drop(data[(data['adults'] == 0) & (data['children'] == 0) & (data['babies'] == 0)].index, inplace=True)

data["adr"] = data["adr"].fillna(data["adr"].mean())

data["reservation_status_date"] = pd.to_datetime(data["reservation_status_date"], format='mixed')

data.drop(["reservation_status_date", "reservation_status"], axis=1, inplace=True)

data = pd.get_dummies(data,columns = ["hotel", "arrival_date_month", "meal", "country", "market_segment", "distribution_channel", "reserved_room_type", "assigned_room_type", "deposit_type", "customer_type"], drop_first=True)

from sklearn.model_selection import train_test_split

X = data.drop("is_canceled", axis=1)
y = data["is_canceled"]
X_train, X_test, y_train, y_test = train_test_split(X, y, test_size=0.3, random_state=42)

print("Data successfully reloaded and preprocessed. Data split into training and testing sets.")
--------------------------------------------------------------------------------------------------------------------------------

from sklearn.linear_model import LogisticRegression
---------------------------------------------------------------------------------------------------------------------

model = LogisticRegression()
model.fit(X_train, y_train)
---------------------------------------------------------------------------------------------------------------------

y_pred = model.predict(X_test)

-------------------------------------------------------------------------------------------------------------------------------------
from sklearn.metrics import accuracy_score, precision_score, recall_score, f1_score

print("Accuracy Score :", accuracy_score(y_test, y_pred))
print("Precision Score :", precision_score(y_test, y_pred))
print("Recall Score :", recall_score(y_test, y_pred))
print("F1 Score :", f1_score(y_test, y_pred))
----------------------------------------------------------------------------------------------------------------------------------------
from sklearn.metrics import confusion_matrix
confusion_matrix(y_test, y_pred)
---------------------------------------------------------------------------------------------------------------------

sns.heatmap(confusion_matrix(y_test, y_pred), annot=True, fmt='d', cmap='Blues')
plt.xlabel('Predicted')
plt.ylabel('Actual')
plt.show()
---------------------------------------------------------------------------------------------------------------------

from sklearn.metrics import classification_report
print(classification_report(y_test, y_pred))
